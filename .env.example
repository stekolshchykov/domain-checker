# Kimi API Configuration
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding

# Internal Service URLs (used inside Docker network)
KIMI_ORCHESTRATOR_URL=http://kimi-orchestrator:4000
DOMAIN_SERVICE_URL=http://domain-service:8000

# Domain Service Settings
APP_ENV=production
PLAYWRIGHT_HEADLESS=true
RATE_LIMIT_SECONDS=1.0
PAGE_TIMEOUT_MS=15000
DOMAIN_SERVICE_TIMEOUT_MS=90000
