# Kimi API Configuration
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding

# Internal Service URLs (used inside Docker network)
KIMI_ORCHESTRATOR_URL=http://kimi-orchestrator:4000
DOMAIN_SERVICE_URL=http://domain-service:8000

# Domain Service Settings
APP_ENV=production
PLAYWRIGHT_HEADLESS=true
RATE_LIMIT_SECONDS=1.0
PAGE_TIMEOUT_MS=15000
MAX_CONCURRENT_DOMAINS=8
MAX_CONCURRENT_REQUESTS=35
REQUEST_TIMEOUT_SECONDS=10
REQUEST_RETRY_ATTEMPTS=3
REQUEST_RETRY_BASE_SECONDS=0.35
REQUEST_RETRY_JITTER_SECONDS=0.25
REQUEST_CACHE_TTL_SECONDS=15
CIRCUIT_BREAKER_FAILURE_THRESHOLD=4
CIRCUIT_BREAKER_OPEN_SECONDS=30
PROVIDER_RELIABILITY_ALPHA=0.15
PROVIDER_RELIABILITY_FLOOR=0.2
DOMAIN_SERVICE_TIMEOUT_MS=90000
